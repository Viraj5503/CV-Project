# Copy to .env and fill in. Never commit .env (gitignored).
ANTHROPIC_API_KEY=sk-ant-...

# Claude model for VLM inspection reports (optional; defaults to claude-opus-4-8)
PCB_VLM_MODEL=claude-sonnet-4-6

# --- Serving (all optional; defaults shown) ---
# PCB_MODEL_PATH=models/best.pt   # YOLO weights the API loads
# PCB_DEVICE=cpu                  # unset -> ultralytics auto-selects (mps/cuda/cpu)
# PCB_API_URL=http://localhost:8000  # where the Streamlit UI finds the API

# --- RAG repair advisor (all optional; defaults shown) ---
# PCB_KB_DIR=knowledge_base       # markdown knowledge base to ingest
# PCB_CHROMA_DIR=data/chroma      # persistent ChromaDB index location
# PCB_EMBED_MODEL=all-MiniLM-L6-v2  # sentence-transformers model (local, free)

# --- RAG generation provider (all optional) ---
# PCB_RAG_PROVIDER=gemini         # anthropic | gemini | none (unset -> auto-detect
#                                 # from keys: anthropic first, then gemini;
#                                 # no key -> extractive mode, passages verbatim)
# GEMINI_API_KEY=...              # free tier from Google AI Studio (no card)
# PCB_RAG_MODEL=gemini-flash-lite-latest  # override the provider's default model
#                                 # (flagship flash models are 20 req/day on
#                                 # free tier as of 2026-07; lite line is usable)

# --- RAG evaluation (Phase 2 Task 3, all optional) ---
# PCB_RAGAS_JUDGE=gemini-flash-lite-latest  # judge model for RAGAS metrics
